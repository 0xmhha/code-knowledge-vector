# build-profiles.env.example — machine-local paths for the build/eval scripts.
#
# Copy to build-profiles.env (git-ignored) and edit the paths for your machine:
#
#   cp build-profiles.env.example build-profiles.env
#   $EDITOR build-profiles.env
#
# scripts/build-knowledge.sh and scripts/pr-retrieval-eval.sh source this file
# automatically when it exists. The Makefile's stablenet targets read GSN_SRC /
# GSN_OUT from the environment, so `set -a; . build-profiles.env; set +a` before
# `make`, or pass them inline (GSN_SRC=... make rebuild-stablenet).
#
# Every value is still overridable per-invocation via the environment; this file
# only supplies the defaults so no machine path lives in a committed script.

# --- shared -----------------------------------------------------------------
# CKG file-filter (files-from) JSON: the set of source files to index.
FILTER=/path/to/code-knowledge-graph/eval/stablenet/stablenet-files-with-tests.json

# --- scripts/build-knowledge.sh ---------------------------------------------
# Source tree to index.
SRC=/path/to/analysis-test-3
# Dataset root: ckg graph in $CKG_DIR/graph-db/, vector index written to
# $CKG_DIR/vector-db/.
CKG_DIR=/path/to/knowledge-data/pr-77-2
# Curated flow corpus JSONL (optional; the build warns and continues if absent).
FLOW_CORPUS=/path/to/go-stablenet/.claude/docs/corpus/corpus.jsonl
# EMBEDDER=ollama
# MODEL=bge-m3
# LANGS=go,solidity

# --- scripts/pr-retrieval-eval.sh -------------------------------------------
# go-stablenet clone with every PR base_sha reachable.
GS=/path/to/go-stablenet
# REPONAME=stable-net/go-stablenet

# --- Makefile (rebuild-stablenet / gsn-smoke) -------------------------------
# go-stablenet source tree and the index output dir.
GSN_SRC=/path/to/go-stablenet
GSN_OUT=./ckv-stablenet
